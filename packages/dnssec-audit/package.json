{
  "name": "@namefi/dnssec-audit",
  "version": "2.1.1",
  "description": "Pure-TS DNSSEC chain-of-trust exporter and offline validator (NSEC + NSEC3). Works in Node and the browser.",
  "license": "MIT",
  "type": "module",
  "author": "D3Serve Labs Inc. dba Namefi (https://namefi.io)",
  "homepage": "https://github.com/d3servelabs/dnssec-audit-ts#readme",
  "bugs": {
    "url": "https://github.com/d3servelabs/dnssec-audit-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d3servelabs/dnssec-audit-ts.git",
    "directory": "packages/dnssec-audit"
  },
  "sideEffects": false,
  "keywords": [
    "dnssec",
    "dns",
    "doh",
    "rfc4034",
    "rfc5155",
    "nsec",
    "nsec3",
    "rrsig",
    "trust-anchor",
    "typescript",
    "pure-js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./walker": {
      "types": "./dist/walker.d.ts",
      "import": "./dist/walker.js",
      "default": "./dist/walker.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js",
      "default": "./dist/resolver.js"
    },
    "./wire": {
      "types": "./dist/wire.d.ts",
      "import": "./dist/wire.js",
      "default": "./dist/wire.js"
    },
    "./nsec": {
      "types": "./dist/nsec.d.ts",
      "import": "./dist/nsec.js",
      "default": "./dist/nsec.js"
    },
    "./trust-anchor": {
      "types": "./dist/trust-anchor.d.ts",
      "import": "./dist/trust-anchor.js",
      "default": "./dist/trust-anchor.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js",
      "default": "./dist/crypto.js"
    },
    "./util": {
      "types": "./dist/util.d.ts",
      "import": "./dist/util.js",
      "default": "./dist/util.js"
    },
    "./canonical": {
      "types": "./dist/canonical.d.ts",
      "import": "./dist/canonical.js",
      "default": "./dist/canonical.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "dnssec-export": "dist/cli/export-dnssec.js",
    "dnssec-validate": "dist/cli/validate-dnssec.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli/export-dnssec.js dist/cli/validate-dnssec.js",
    "export": "node --experimental-strip-types --no-warnings=ExperimentalWarning src/cli/export-dnssec.ts",
    "validate": "node --experimental-strip-types --no-warnings=ExperimentalWarning src/cli/validate-dnssec.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --no-warnings=ExperimentalWarning --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
